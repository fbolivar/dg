# Modo demostración — recorrido guiado del prototipo
# true  = la app se alimenta de datos de demostración (src/shared/data/mock.ts)
# false = la app se alimenta de Supabase (producción)
NEXT_PUBLIC_USE_MOCK=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic Claude API (para Copiloto y generación de Legal Notes)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
