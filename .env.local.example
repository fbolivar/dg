# Modo demostración — recorrido guiado del prototipo
# true  = la app se alimenta de datos de demostración (src/shared/data/mock.ts)
# false = la app se alimenta de Supabase (producción)
NEXT_PUBLIC_USE_MOCK=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SERVICE ROLE (secreto, SOLO servidor): el navegador nunca habla con Supabase.
# Todo el acceso a datos pasa por Server Actions con esta llave (bypassa RLS).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Rate-limit en producción (Vercel KV / Upstash). Se inyectan al crear el store
# en Vercel. Si faltan, el rate-limit cae a un contador en memoria (solo dev).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Anthropic Claude API (para Copiloto y generación de Legal Notes)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Secreto para el cron de sincronización
CRON_SECRET=genera_uno_con_openssl_rand_hex_32

# Clave para cifrar los respaldos automáticos en reposo (AES-256-GCM, 32 bytes hex).
# Genera con: openssl rand -hex 32
# Si se omite, se usa TOKEN_ENCRYPTION_KEY; si tampoco está, el respaldo se sube
# SIN cifrar (el endpoint lo avisa en su respuesta).
BACKUP_ENCRYPTION_KEY=

# Secreto para firmar sesiones (autenticación local)
JWT_SECRET=genera_uno_con_openssl_rand_hex_32

# ─── DGA-Time · Captura inteligente: integraciones de correo y calendario ─────
# Clave para cifrar los tokens OAuth en la BD (32 bytes hex). Genera con:
#   openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Google Workspace (Calendar + Gmail). Ver GUIA-INTEGRACIONES.md
# Redirect URI a registrar: {NEXT_PUBLIC_SITE_URL}/api/integrations/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft 365 (Outlook + Calendario). Ver GUIA-INTEGRACIONES.md
# Redirect URI a registrar: {NEXT_PUBLIC_SITE_URL}/api/integrations/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common
